rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.active == true
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    match /products/{productId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if isAdmin() && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
