rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function profile() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function isAdmin() { return signedIn() && profile().active == true && profile().role == "admin"; }
    function isSeller() { return signedIn() && profile().active == true && profile().role == "seller"; }
    function allowedLocation(locationId) { return isSeller() && locationId in profile().allowedLocationIds; }
    function locationNotDeleted(location) { return !("deleted" in location) || location.deleted != true; }
    function locationNotPaused(location) {
      return !("manualInactiveUntil" in location)
        || location.manualInactiveUntil == null
        || location.manualInactiveUntil <= request.time;
    }
    function locationScheduleStarted(location) {
      return !("scheduleStartAt" in location)
        || location.scheduleStartAt == null
        || location.scheduleStartAt <= request.time;
    }
    function locationScheduleNotEnded(location) {
      return !("scheduleEndAt" in location)
        || location.scheduleEndAt == null
        || location.scheduleEndAt >= request.time;
    }
    function autoActiveLocation(location) {
      return "autoActivityManaged" in location
        && location.autoActivityManaged == true
        && locationNotPaused(location)
        && locationScheduleStarted(location)
        && locationScheduleNotEnded(location)
        && (location.active == true
          || ("manualInactiveUntil" in location
            && location.manualInactiveUntil != null
            && location.manualInactiveUntil <= request.time));
    }
    function legacyActiveLocation(location) {
      return (!("autoActivityManaged" in location) || location.autoActivityManaged != true)
        && locationNotPaused(location)
        && (location.active == true
          || ("manualInactiveUntil" in location
            && location.manualInactiveUntil != null
            && location.manualInactiveUntil <= request.time));
    }
    function activeAllowedLocation(locationId) {
      let location = get(/databases/$(database)/documents/locations/$(locationId)).data;
      return allowedLocation(locationId) && locationNotDeleted(location)
        && (autoActiveLocation(location) || legacyActiveLocation(location));
    }
    function validPaymentPart(part) {
      return part is map
        && part.keys().hasOnly(["method", "label", "amount"])
        && part.method in ["credit", "debit", "alias", "cash"]
        && ((part.method == "credit" && part.label == "Pago Credito")
          || (part.method == "debit" && part.label == "Pago debito")
          || (part.method == "alias" && part.label == "Pago Alias")
          || (part.method == "cash" && part.label == "Pago eft"))
        && part.amount is int && part.amount > 0;
    }
    function validSinglePayment(data) {
      return data.paymentMethod in ["credit", "debit", "alias", "cash"]
        && ((data.paymentMethod == "credit" && data.paymentMethodLabel == "Pago Credito")
          || (data.paymentMethod == "debit" && data.paymentMethodLabel == "Pago debito")
          || (data.paymentMethod == "alias" && data.paymentMethodLabel == "Pago Alias")
          || (data.paymentMethod == "cash" && data.paymentMethodLabel == "Pago eft"));
    }
    function validMultiplePayment(data) {
      let size = data.payments.size();
      return data.paymentMethod == "multiple" && data.paymentMethodLabel == "+2 pagos"
        && data.payments is list && size >= 2 && size <= 4
        && validPaymentPart(data.payments[0]) && validPaymentPart(data.payments[1])
        && (size < 3 || validPaymentPart(data.payments[2]))
        && (size < 4 || validPaymentPart(data.payments[3]))
        && data.payments[0].method != data.payments[1].method
        && (size < 3 || (data.payments[2].method != data.payments[0].method && data.payments[2].method != data.payments[1].method))
        && (size < 4 || (data.payments[3].method != data.payments[0].method && data.payments[3].method != data.payments[1].method && data.payments[3].method != data.payments[2].method))
        && data.payments[0].amount + data.payments[1].amount
          + (size >= 3 ? data.payments[2].amount : 0)
          + (size == 4 ? data.payments[3].amount : 0) == data.total;
    }
    function validPayment(data) { return validSinglePayment(data) || validMultiplePayment(data); }

    match /users/{uid} {
      allow get: if isAdmin() || (signedIn() && request.auth.uid == uid);
      allow list, create, update, delete: if isAdmin();
    }

    match /locations/{locationId} {
      allow get: if isAdmin() || allowedLocation(locationId);
      allow list, create, update, delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isAdmin() || (isSeller() && resource.data.active == true);
      allow create, update, delete: if isAdmin();
    }

    match /productCategories/{categoryId} {
      allow read: if isAdmin() || (isSeller() && resource.data.active == true
        && (!("deleted" in resource.data) || resource.data.deleted != true));
      allow create, update, delete: if isAdmin();
    }

    match /discounts/{discountId} {
      allow read: if isAdmin() || (isSeller() && resource.data.active == true);
      allow create, update, delete: if isAdmin();
    }

    match /locationStock/{locationId} {
      allow read, write: if isAdmin();
      match /items/{productId} {
        allow read: if isAdmin() || allowedLocation(locationId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (activeAllowedLocation(locationId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["currentStock", "updatedAt"])
          && request.resource.data.currentStock is int);
      }
    }

    match /sales/{saleId} {
      allow get: if isAdmin() || (isSeller() && (saleId.matches('^offline_' + request.auth.uid + '_.*$')
        || resource.data.sellerId == request.auth.uid));
      allow list: if isAdmin() || (isSeller() && resource.data.sellerId == request.auth.uid);
      allow create: if isAdmin() || (isSeller()
        && request.resource.data.sellerId == request.auth.uid
        && activeAllowedLocation(request.resource.data.locationId)
        && request.resource.data.status == "active"
        && validPayment(request.resource.data)
        && request.resource.data.total >= 0);
      allow update: if isAdmin() || (isSeller()
        && resource.data.sellerId == request.auth.uid
        && request.resource.data.sellerId == resource.data.sellerId
        && request.resource.data.locationId == resource.data.locationId
        && activeAllowedLocation(resource.data.locationId)
        && resource.data.status == "active"
        && request.resource.data.status in ["active", "cancelled"]
        && (request.resource.data.status == "cancelled" || validPayment(request.resource.data))
        && request.resource.data.total >= 0);
      allow delete: if false;
    }

    match /stockMovements/{movementId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAdmin() || (isSeller()
        && request.resource.data.userId == request.auth.uid
        && allowedLocation(request.resource.data.locationId));
    }

    match /counters/{counterId} {
      allow get: if isAdmin() || isSeller();
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSeller() && allowedLocation(request.resource.data.locationId) && request.resource.data.lastNumber == 1);
      allow update: if isAdmin() || (isSeller()
        && request.resource.data.locationId == resource.data.locationId
        && allowedLocation(resource.data.locationId)
        && request.resource.data.lastNumber == resource.data.lastNumber + 1);
      allow delete: if false;
    }

    match /{document=**} { allow read, write: if false; }
  }
}
